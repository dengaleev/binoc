{
	servers {
		metrics
	}
}

:80 {
	# /metrics is served without tracing to avoid noise from Prometheus scrapes
	handle /metrics {
		reverse_proxy app:8080
	}

	tracing

	handle / {
		root * /srv
		file_server
	}
	handle /echo* {
		reverse_proxy app:8080
	}
	handle /notes* {
		reverse_proxy app:8080
	}
	handle /chain* {
		reverse_proxy app:8080
	}
	handle /healthz {
		reverse_proxy app:8080
	}
	handle /readyz {
		reverse_proxy app:8080
	}
}
