{
	admin 0.0.0.0:2019
	metrics
}

:80 {
	# Health probes and metrics are served without tracing to avoid noise
	handle /metrics {
		reverse_proxy app:8080
	}
	handle /healthz {
		reverse_proxy app:8080
	}
	handle /readyz {
		reverse_proxy app:8080
	}

	tracing

	handle / {
		root * /srv
		file_server
	}
	handle /time {
		root * /srv
		templates {
			mime application/json
		}
		header Content-Type application/json
		rewrite * /time.json.tmpl
		file_server
	}
	handle /echo* {
		reverse_proxy app:8080
	}
	handle /notes* {
		reverse_proxy app:8080
	}
	handle /chain* {
		reverse_proxy app:8080
	}
	handle /random* {
		reverse_proxy app:8080
	}
}
